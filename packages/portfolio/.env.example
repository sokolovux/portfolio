# Upstash Redis — create a free database at https://upstash.com
# Copy from Upstash dashboard → your database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Local dev: copy to .env.local (quotes optional here).
#
# Production (Vercel): Project → Settings → Environment Variables
#   Name:  UPSTASH_REDIS_REST_URL
#   Value: https://xxxx.upstash.io          ← no quotes
#   Name:  UPSTASH_REDIS_REST_TOKEN
#   Value: AXXX...                          ← no quotes
#   Scope: Production (+ Preview if needed)
#
# Or connect via Upstash integration (recommended):
#   Upstash Console → your database → Settings → Connect to Vercel
#
# Redeploy after saving env vars.
